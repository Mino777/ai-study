{
  "name": "ai-study",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/validate-content.mjs && node scripts/generate-content-manifest.mjs",
    "validate": "node scripts/validate-content.mjs",
    "dev": "concurrently \"node scripts/watch-content.mjs\" \"next dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "new-entry": "node scripts/new-entry.mjs",
    "generate-lesson": "node scripts/generate-lesson.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "embed-content": "node scripts/embed-content.mjs",
    "search": "node scripts/search.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@shikijs/rehype": "^4.0.2",
    "@uiw/react-md-editor": "^4.1.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.14.0",
    "next": "^16.2.3",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
